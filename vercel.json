{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" }
  ]
}
{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "\\/(.*\\.(?:css|js|png|jpg|jpeg|svg|gif|woff2?|ttf))$", "dest": "/$1" },
    { "src": "\\/(.*)", "dest": "/index.html" }
  ]
}
